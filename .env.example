# Copy to .env. Never commit real API keys or tokens.

# Zero-key local demo:
SELFPLAY_RUNTIME=mock
SELFPLAY_TASK=Docker self-evolution smoke test
SELFPLAY_DB=data/selfplay.sqlite

# Anthropic / Claude-compatible runtime:
# SELFPLAY_RUNTIME=claude
# ANTHROPIC_AUTH_TOKEN=replace-me
# ANTHROPIC_API_KEY=replace-me
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI-compatible provider values for future adapters / Codex bridges:
# OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.5
